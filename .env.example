# Public site origin — used for canonical URLs, sitemap and structured data.
NEXT_PUBLIC_SITE_URL=https://buymeatee.com

# Early-access form submission endpoint (server-side only, never exposed to the browser).
# Point this at any service accepting a JSON POST (Formspree, Loops, ConvertKit,
# a Supabase function, …). Leave empty to show an honest "not connected yet" state.
EARLY_ACCESS_API_URL=

# ---------------------------------------------------------------------------
# Supabase (project ref hjpfycbamwwpemsrrsqy — ADR-008)
# ---------------------------------------------------------------------------
# URL + anon key are public by design (RLS is the security boundary).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-side ONLY. Never expose to the browser, never commit.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Stripe (ADR-009). NEVER commit real keys. Test and live use different keys
# AND different webhook signing secrets — configure them per environment.
# ---------------------------------------------------------------------------
# Publishable key (browser-safe). Not currently required — Stripe-hosted
# Checkout works via server-created session URLs — reserved for embedded flows.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret key (sk_test_… / sk_live_…): trusted server code only.
STRIPE_SECRET_KEY=
# Signing secret of THIS environment's webhook endpoint (whsec_…).
STRIPE_WEBHOOK_SECRET=

# Connect + Checkout URLs. Optional — they default to NEXT_PUBLIC_SITE_URL
# paths shown below and must stay on that origin (open-redirect protection).
# {GIFT_PUBLIC_ID} is substituted per checkout.
STRIPE_CONNECT_RETURN_URL=
# default: https://buymeatee.com/settings/payments/return
STRIPE_CONNECT_REFRESH_URL=
# default: https://buymeatee.com/api/connect/refresh
STRIPE_CHECKOUT_SUCCESS_URL=
# default: https://buymeatee.com/gifts/{GIFT_PUBLIC_ID}/thanks
STRIPE_CHECKOUT_CANCEL_URL=
# default: https://buymeatee.com/gifts/{GIFT_PUBLIC_ID}/cancelled

# Fee model (documented commercial assumptions — lib/payments/config.ts).
# Platform fee in basis points of the gift (500 = 5%).
STRIPE_PLATFORM_FEE_BPS=500
# Assumed card-processing percentage (decimal, max 2 places; "1.5" = 1.5%).
STRIPE_PAYMENT_FEE_PERCENT=1.5
# Assumed fixed processing fee per payment, integer minor units.
STRIPE_PAYMENT_FEE_FIXED_GBP=20
STRIPE_PAYMENT_FEE_FIXED_EUR=25
# Gift bounds, integer minor units (100 = £1.00 / €1.00).
STRIPE_MINIMUM_GIFT_GBP=100
STRIPE_MINIMUM_GIFT_EUR=100
STRIPE_MAXIMUM_GIFT_GBP=50000
STRIPE_MAXIMUM_GIFT_EUR=50000
# Countries recipients may onboard from (ISO alpha-2, comma-separated).
STRIPE_CONNECT_ALLOWED_COUNTRIES=GB,IE,DE,FR,ES,NL,BE,AT,PT,FI

# Optional bearer token letting a scheduler call POST /api/admin/reconcile.
RECONCILIATION_SECRET=
